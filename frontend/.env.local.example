# Copy to .env.local for local development
NEXT_PUBLIC_API_URL=http://localhost:8000

# Auth0 (fill in from your Auth0 dashboard)
# SPA app -> Settings
NEXT_PUBLIC_AUTH0_DOMAIN=dev-xxxx.us.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your-spa-client-id
# Auth0 API -> Identifier (must match backend AUTH0_AUDIENCE)
NEXT_PUBLIC_AUTH0_AUDIENCE=https://api.optivault.local
