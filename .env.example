# Copy this file to .env and fill in real values. Never commit the real .env.

ENVIRONMENT=local

# Overridden by docker-compose for containers; used if you run uvicorn/celery directly on your host
DATABASE_URL=postgresql://optivault:optivault@localhost:5432/optivault
REDIS_URL=redis://localhost:6379/0

# Generate a real secret for anything beyond local dev:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION

AWS_DEFAULT_REGION=us-east-1

# Only needed if you're running a scan against your own bucket locally
# without a role_arn (i.e. using your default AWS CLI credentials).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
